{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "windows-local-x86",
      "inherits": "windows-base",
      "architecture": "Win32"
    },
    {
      "name": "linux-rhel8-release",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}-make",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-local-x86-debug",
      "configurePreset": "windows-local-x86",
      "configuration": "Debug"
    },
    {
      "name": "linux-rhel8-release",
      "configurePreset": "linux-rhel8-release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-local-x86-debug",
      "configurePreset": "windows-local-x86",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-rhel8-release",
      "configurePreset": "linux-rhel8-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
